# Environment: dev, staging, production
ENVIRONMENT=dev

# LLM 
LLM_PROVIDER=
LLM_API_KEY=
LLM_API_ENDPOINT=
LLM_MODEL=
LLM_API_VERSION=

# Embedding 
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_API_ENDPOINT=
EMBEDDING_MODEL=
EMBEDDING_API_VERSION=

# Similarity scoring configuration
SIMILARITY_MAX_LENGTH=

# Default scoring thresholds (0.0 - 1.0) 
THRESHOLD_ROUGE=0.5 
THRESHOLD_COSINE=0.7 
THRESHOLD_LLM_JUDGE=1.0 
THRESHOLD_RULE_BASED=1.0
