# Environment: dev, staging, production
ENVIRONMENT=

# LLM
LLM_PROVIDER=
LLM_API_KEY=
LLM_API_ENDPOINT=
LLM_MODEL=
LLM_API_VERSION=

# Embedding
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_API_ENDPOINT=
EMBEDDING_MODEL=
EMBEDDING_API_VERSION=

# Similarity scoring configuration
SIMILARITY_MAX_LENGTH=

# Default scoring thresholds (0.0 - 1.0)
THRESHOLD_ROUGE=
THRESHOLD_COSINE=
THRESHOLD_LLM_JUDGE=
THRESHOLD_RULE_BASED=

# Logging level
LOG_LEVEL=
# Database
DB_DRIVER=
DB_HOST=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# For pgadmin stuff (Only needed for development)
PGADMIN_MAIL=
PGADMIN_PW=

# Celery broker (the queue tasks are dispatched through). The result backend
# uses the same Postgres connection as the app (see DB_* above), so it doesn't
# need its own env vars.
REDIS_HOST=
REDIS_PORT=
